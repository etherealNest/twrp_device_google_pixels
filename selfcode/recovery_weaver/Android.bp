
cc_binary {
    name: "recovery_weaver",
    srcs: ["recovery_weaver.cpp"],
    recovery: true,
    shared_libs: [
        "android.hardware.weaver-V2-ndk",
        "libbase",
        "libbinder_ndk",
    ],
    cflags: [
        "-Wall",
        "-Wextra",
        "-Werror",
        "-Wno-unused-parameter",
    ],
}
