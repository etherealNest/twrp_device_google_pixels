
cc_binary {
    name: "recovery_storageproxyd",
    srcs: ["recovery_storageproxyd.c"],
    recovery: true,
    static_executable: true,
    cflags: [
        "-Wall",
        "-Wextra",
        "-Werror",
        "-Wno-unused-parameter",
        "-Wno-unused-but-set-variable",
        "-O2",
    ],
}
